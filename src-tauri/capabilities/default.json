{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "default",
  "description": "Default permissions for the app",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/klin-worker",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/klin-worker",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
