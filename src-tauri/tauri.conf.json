{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KLIN",
  "version": "1.0.0",
  "identifier": "com.klin.app",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KLIN",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "dragDropEnabled": true,
        "additionalBrowserArgs": "--disable-features=msTrackingPrevention"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/llama-server",
      "binaries/klin-worker"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["klin"]
      }
    }
  }
}
