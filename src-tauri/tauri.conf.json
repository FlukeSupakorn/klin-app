{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klin App",
  "version": "1.0.0",
  "identifier": "com.klin.app",
  "build": {
    "beforeDevCommand": "bun run dev:vite",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Klin App",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
