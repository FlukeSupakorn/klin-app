# Environment variables for Klin app
NODE_ENV=development

# Google Calendar OAuth 2.0 Client ID
# Create a "Web application" client ID at https://console.cloud.google.com/
# Add "http://localhost:1420" to "Authorized JavaScript origins"
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

VITE_SKIP_ONBOARDING=true

# Dev external services
# Set this to true when using a source-run klin-worker.
# KLIN_WORKER_EXTERNAL=true

# Tauri sidecar / production binary workflow
KLIN_CHAT_MODEL_PATH=models/your-model.gguf
KLIN_EMBED_MODEL_PATH=models/your-embed-model.gguf
KLIN_MMPROJ_PATH=models/mmproj-F16.gguf
KLIN_N_GPU_LAYERS=-1
KLIN_CTX_SIZE=4096
# KLIN_LLAMA_PORT=8080
# KLIN_LLAMA_IDLE_TIMEOUT=300